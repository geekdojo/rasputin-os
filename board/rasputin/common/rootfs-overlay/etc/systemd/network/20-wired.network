# Wired uplink — match any kernel/udev name an onboard NIC can get:
# udev predictable naming gives enp*/eno*/ens* (enp1s0 on the Mu); plain
# eth0 only survives with net.ifnames=0. Container/virtual interfaces
# (docker0, br-*, veth*) intentionally don't match.
[Match]
Name=en* eth*

[Network]
DHCP=yes
# mDNS per-link opt-in (defaults to false): resolved answers <hostname>.local
# on this link only when networkd sets this. Global responder mode lives in
# etc/systemd/resolved.conf.d/10-rasputin-mdns.conf. Which hostname is
# announced is decided per-role by rasputin-hostname.service — only the
# controlplane answers rasputin.local.
MulticastDNS=yes
# IPv4 link-local FALLBACK for the dumb-switch/no-DHCP bench scenario.
# "ipv4" = IPv4 LL only while DHCPv4 has no lease: systemd 256's networkd
# starts sd-ipv4ll on DHCP transient failure and drops the 169.254.x address
# the moment a lease is acquired (networkd-dhcp4.c dhcp4_address_acquired →
# sd_ipv4ll_stop). So with working DHCP no extra address ever exists to
# pollute the api's cert SANs. NOT "yes" — that also brings up IPv6
# link-local, which Rasputin is IPv4-only (LOCKED decision #9) forbids.
LinkLocalAddressing=ipv4
# Refuse router advertisements / SLAAC so no IPv6 address appears via RA.
IPv6AcceptRA=no
