# Overlay-managed fstab — n100 (amd64, GPT). Installed to /etc/fstab by
# post-build.sh (per-SoC, because the persistent partition is addressed
# differently per partition-table: GPT PARTLABEL here, MBR PARTUUID on the rpi).
# Buildroot's generated fstab is replaced, so the /dev/root line must stay.
/dev/root	/	auto	rw	0	1

# Persistent state (node identity, role marker, api data dir). The image ships
# this partition PRE-FORMATTED as an empty ext4 (post-image.sh builds
# persistent.ext4; genimage embeds it) so a reflash writes a correct superblock
# over any stale fs left by a prior disk tenant — without that, makefs skips a
# pre-existing (oversized) fs and the mount fails on geometry. x-systemd.makefs
# stays as a belt-and-suspenders fallback (formats only if somehow blank);
# x-systemd.growfs grows the fs to the partition, and rasputin-growpart first
# extends the partition to fill the medium. nofail: a wedged persistent
# partition skips provisioning (units RequiresMountsFor this path) but the system
# still boots to something debuggable. fsck passno 0 — keep it that way unless
# fsck.ext4 ships.
PARTLABEL=persistent	/var/lib/rasputin	ext4	defaults,nofail,x-systemd.makefs,x-systemd.growfs	0	0

# The boot ESP (GRUB + kernel + grubenv), mounted rw so RAUC's grub-editenv can
# update the A/B boot-counter (system.conf grubenv=/run/rasputin-esp/...); GRUB
# reads the same grubenv at boot from its own prefix. By PARTLABEL "esp" — the
# seed FAT is now its own auto-mounting RASPUTIN-OS partition (so it isn't hidden
# in the Win/macOS GUI like an ESP). nofail: a wedged ESP must not block boot.
PARTLABEL=esp	/run/rasputin-esp	vfat	rw,nofail	0	0
