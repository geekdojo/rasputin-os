# Overlay-managed fstab — rpi (arm64, MBR). Installed to /etc/fstab by
# post-build.sh (per-SoC). MBR has no PARTLABEL, so the persistent partition is
# addressed by PARTUUID (disk-signature 0x52415350 + partition number; persistent
# = p7 → 52415350-07). MUST match genimage's disk-signature + partition order.
# Buildroot's generated fstab is replaced, so the /dev/root line must stay.
/dev/root	/	auto	rw	0	1

# Persistent state (node identity, role marker, api data dir). The image ships
# this partition PRE-FORMATTED as an empty ext4 (post-image.sh builds
# persistent.ext4; genimage embeds it) so a reflash writes a correct superblock
# over any stale fs left by a prior disk tenant — without that, makefs skips a
# pre-existing (oversized) fs and the mount fails on geometry. x-systemd.makefs
# stays as a belt-and-suspenders fallback (formats only if somehow blank);
# x-systemd.growfs grows the fs to the partition. nofail: a wedged persistent
# partition skips provisioning (units RequiresMountsFor this path) but the system
# still boots to something debuggable. fsck passno 0 — keep it that way unless
# fsck.ext4 ships.
#
# rasputin-growpart extends the partition to fill the medium on first boot (it
# grew MBR-aware in 2026.07.1-dev.80 — the extended container + this logical via
# cloud-utils growpart; it gates on the /var/lib/rasputin MOUNT, so it runs on
# the rpi too). x-systemd.growfs then grows the fs to the enlarged partition.
PARTUUID=52415350-07	/var/lib/rasputin	ext4	defaults,nofail,x-systemd.makefs,x-systemd.growfs	0	0
